-- Watch for new/removed descendants every 3 seconds
task.spawn(function()
    while true do
        task.wait(3)
        -- Quick count check first (cheap)
        local found = ScanWorkspace()
        if #found ~= #ScannedEggs then
            RefreshList()
        else
            -- Also check if any existing eggs were removed from workspace
            local anyGone = false
            for _, egg in ipairs(ScannedEggs) do
                if not egg or not egg.Parent then
                    anyGone = true
                    break
                end
            end
            if anyGone then RefreshList() end
        end
    end
end)

