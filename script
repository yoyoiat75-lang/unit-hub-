    -- ===== IMPROVED WALK TO EGG =====
    local isAutoRunning = false

    local function WalkToEgg(targetObj)
        local character = LocalPlayer.Character
        if not character then return end
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local root     = character:FindFirstChild("HumanoidRootPart")
        if not humanoid or not root then return end
        if not targetObj or not targetObj.Parent then return end

        local targetPos = (targetObj:IsA("Model") and targetObj:GetPivot().Position or targetObj.Position)

        -- Direct distance check — if close enough, just press E
        if (root.Position - targetPos).Magnitude < 10 then
            VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.E, false, game)
            task.wait(0.1)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
            task.wait(0.5)
            return
        end

        local path = PathfindingService:CreatePath({
            AgentRadius   = 2,
            AgentHeight   = 5,
            AgentCanJump  = true,
            AgentCanClimb = true,
            WaypointSpacing = 4,
        })

        local success, err = pcall(function()
            path:ComputeAsync(root.Position, targetPos)
        end)

        if not success or path.Status ~= Enum.PathStatus.Success then
            -- Fallback: direct move
            humanoid:MoveTo(targetPos)
            local t = tick()
            repeat task.wait(0.1) until (root.Position - targetPos).Magnitude < 8 or tick() - t > 10
            VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.E, false, game)
            task.wait(0.1)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
            task.wait(0.5)
            return
        end

        local waypoints = path:GetWaypoints()
        local blocked = false

        local blockedConn = path.Blocked:Connect(function(idx)
            if idx >= 1 then blocked = true end
        end)

        for i, wp in ipairs(waypoints) do
            if blocked or not isAutoRunning then break end
            if not targetObj.Parent then break end

            -- Jump waypoints
            if wp.Action == Enum.PathWaypointAction.Jump then
                humanoid.Jump = true
                task.wait(0.15)
            end

            humanoid:MoveTo(wp.Position)

            local moveStart = tick()
            local lastPos   = root.Position
            local stuckTime = 0

            -- Wait until reached or timeout
            local reached = false
            while not reached do
                task.wait(0.1)

                local cur  = root.Position
                local dist = (cur - wp.Position).Magnitude

                if dist < 5 then
                    reached = true
                    break
                end

                -- Stuck detection
                local moved = (cur - lastPos).Magnitude
                if moved < 0.5 then
                    stuckTime += 0.1
                else
                    stuckTime = 0
                end
                lastPos = cur

                -- Jump if stuck
                if stuckTime >= 0.8 then
                    humanoid.Jump = true
                    task.wait(0.35)
                    humanoid.Jump = true
                    stuckTime = 0
                end

                -- Hard timeout per waypoint
                if tick() - moveStart > 5 then
                    break
                end
            end

            -- Early exit if now close enough to egg
            if targetObj.Parent then
                local eggPos = targetObj:IsA("Model") and targetObj:GetPivot().Position or targetObj.Position
                if (root.Position - eggPos).Magnitude < 8 then break end
            end
        end

        blockedConn:Disconnect()

        task.wait(0.1)
        VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.E, false, game)
        task.wait(0.1)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        task.wait(0.5)
    end

