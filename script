local function ScanWorkspace()
    local found = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if TargetSet[string.lower(obj.Name)] then
            table.insert(found, obj)
        end
    end
    return found
end

local function RefreshList()
    -- Clear old UI rows only
    for _, v in ipairs(Scroll:GetChildren()) do
        if v:IsA("Frame") then v:Destroy() end
    end
    ClearESP()
    ScannedEggs = {}
    itemCheckMap = {}
    -- Keep SelectedEggs intact so selections survive a refresh

    local found = ScanWorkspace()
    local BATCH = 3
    for i, obj in ipairs(found) do
        table.insert(ScannedEggs, obj)
        AddItem(obj.Name, obj, i)
        AddESP(obj)
        if i % BATCH == 0 then task.wait() end
    end

    CountLabel.Text = #ScannedEggs .. " egg" .. (#ScannedEggs ~= 1 and "s" or "")

    if #ScannedEggs == 0 then
        local Empty = Instance.new("TextLabel", Scroll)
        Empty.Size = UDim2.new(1, 0, 0, 40)
        Empty.BackgroundTransparency = 1
        Empty.Text = "no eggs found"
        Empty.TextColor3 = Color3.fromRGB(70, 70, 70)
        Empty.Font = Enum.Font.Gotham
        Empty.TextSize = 15
    end
end

