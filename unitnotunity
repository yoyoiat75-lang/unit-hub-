-- ================================================================
task.spawn(function()
    while task.wait(0.15) do
        local hum=getHum(); if not hum then continue end
        local hp=math.floor(hum.Health)
        local maxHP=math.max(math.floor(hum.MaxHealth),1)
        local pct=math.clamp(hp/maxHP,0,1)
        HPLbl.Text="HP  "..hp.." / "..maxHP
        local col=pct>0.6 and W.success or pct>0.3 and W.warn or W.danger
        tw(HPFill,0.2,{Size=UDim2.new(pct,0,1,0),BackgroundColor3=col})
        ivHP.Text=hp.." / "..maxHP
        if F.AutoSafe and not F.SafeCooldown and hp>0 and hp<=F.SafeHP then
            F.SafeCooldown=true
            if pfActive then stopPathfinding("auto-safe") end
            local ok,msg=doSafeTeleport()
            notify(ok and "Auto safe spawn triggered" or "Safe spawn failed: "..msg, ok and W.success or W.danger)
            task.delay(5,function() F.SafeCooldown=false end)
        end
    end
end)

