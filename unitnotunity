local notifQ={}; local notifBusy=false
local function notify(msg, color)
    table.insert(notifQ,{msg=msg, col=color or Color3.fromRGB(200,228,255)})
    if notifBusy then return end
    notifBusy=true
    task.spawn(function()
        while #notifQ>0 do
            local n=table.remove(notifQ,1)
            NotifTxt.Text="  "..n.msg; NotifTxt.TextColor3=n.col
            NotifStrip.BackgroundColor3 =
                n.col==W.danger  and Color3.fromRGB(70,10,10) or
                n.col==W.success and Color3.fromRGB(8,36,8)   or
                Color3.fromRGB(0,50,100)
            tw(NotifStrip,0.14,{Size=UDim2.new(1,0,0,22)})
            task.wait(2.8)
            tw(NotifStrip,0.14,{Size=UDim2.new(1,0,0,0)})
            task.wait(0.18)
        end
        notifBusy=false
    end)
end

