local alertHideTask = nil
local alertShowing  = false

local function showAlert(label, dist, col)
    -- tint banner to entity colour
    local r,g,b = math.floor(col.R*255), math.floor(col.G*255), math.floor(col.B*255)
    local function dim(v) return math.max(0, math.floor(v*0.55)) end
    AlertBanner.BackgroundColor3 = Color3.fromRGB(dim(r), dim(g), dim(b))
    AStroke.Color = col
    ABGrad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(math.min(255,math.floor(r*0.65)), math.min(255,math.floor(g*0.32)), math.min(255,math.floor(b*0.32)))),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(math.min(255,math.floor(r*0.36)), math.min(255,math.floor(g*0.18)), math.min(255,math.floor(b*0.18)))),
    }
    ATitle.Text      = "⚠  "..label.." NEARBY"
    ATitle.TextColor3 = col
    ASub.Text        = "Image entity  ·  "..math.floor(dist).." studs away"
    ASub.TextColor3  = Color3.fromRGB(
        math.min(255, math.floor(r*0.9+120)),
        math.min(255, math.floor(g*0.5+100)),
        math.min(255, math.floor(b*0.5+100))
    )

    if not alertShowing then
        alertShowing = true
        AlertBanner.Visible = true
        tw(AlertBanner, 0.20, {Position=UDim2.new(0.5,0,0,12)})
    end

    -- pulse border twice
    task.spawn(function()
        for _=1,2 do
            tw(AStroke,0.15,{Transparency=0.75}); task.wait(0.2)
            tw(AStroke,0.15,{Transparency=0});    task.wait(0.2)
        end
    end)

    if alertHideTask then task.cancel(alertHideTask) end
    alertHideTask = task.delay(4.5, function()
        tw(AlertBanner, 0.20, {Position=UDim2.new(0.5,0,-0.18,0)})
        task.wait(0.26); AlertBanner.Visible=false; alertShowing=false; alertHideTask=nil
    end)
end

