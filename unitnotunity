local function worldToRadar(selfPos, selfLookXZ, targetPos)
    local delta = targetPos - selfPos
    local dx, dz = delta.X, delta.Z
    local cos, sin = selfLookXZ.X, selfLookXZ.Z
    local rx =  dx*cos + dz*sin
    local ry = -dx*sin + dz*cos
    local scale = (RADAR_SIZE/2) / RADAR_RANGE
    return rx*scale, ry*scale
end

task.spawn(function()
    while task.wait(0.06) do
        if not F.RadarEnabled then continue end
        local hrp = getHRP(); if not hrp then continue end
        local selfPos = hrp.Position
        local look    = hrp.CFrame.LookVector
        local lookXZ  = Vector3.new(look.X, 0, look.Z).Unit

        local poolIdx = 0
        local half = RADAR_SIZE / 2

        local function placeDot(wx, wy, col)
            poolIdx += 1
            if poolIdx > DOT_POOL_SIZE then return end
            local d = dotPool[poolIdx]
            d.BackgroundColor3 = col
            d.Position = UDim2.new(0, half+wx - RADAR_DOT/2, 0, half+wy - RADAR_DOT/2)
            d.Visible = true
        end

        for _, data in pairs(entityCache) do
            if data.pp then
                local rx, ry = worldToRadar(selfPos, lookXZ, data.pp.Position)
                if math.abs(rx) <= half and math.abs(ry) <= half then
                    placeDot(rx, ry, W.danger)
                end
            end
        end

        local scrapDrawn = 0
        for obj in pairs(scrapCache) do
            if scrapDrawn >= 20 then break end
            local pos
            if obj:IsA("BasePart") and obj.Parent then pos = obj.Position
            elseif obj:IsA("Model") and obj.PrimaryPart and obj.Parent then pos = obj.PrimaryPart.Position end
            if pos then
                local rx, ry = worldToRadar(selfPos, lookXZ, pos)
                if math.abs(rx) <= half and math.abs(ry) <= half then
                    placeDot(rx, ry, W.gold); scrapDrawn += 1
                end
            end
        end

        for obj in pairs(cpCache) do
            if obj.Parent then
                local pos
                if obj:IsA("BasePart") then pos = obj.Position
                elseif obj:IsA("Model") and obj.PrimaryPart then pos = obj.PrimaryPart.Position end
                if pos then
                    local rx, ry = worldToRadar(selfPos, lookXZ, pos)
                    if math.abs(rx) <= half and math.abs(ry) <= half then
                        placeDot(rx, ry, W.teal)
                    end
                end
            end
        end

        for _, p in ipairs(PLR:GetPlayers()) do
            if p ~= LP and p.Character then
                local rp = p.Character:FindFirstChild("HumanoidRootPart")
                if rp then
                    local rx, ry = worldToRadar(selfPos, lookXZ, rp.Position)
                    if math.abs(rx) <= half and math.abs(ry) <= half then
                        placeDot(rx, ry, W.success)
                    end
                end
            end
        end

        for i=poolIdx+1, DOT_POOL_SIZE do
            dotPool[i].Visible = false
        end
    end
    for i=1,DOT_POOL_SIZE do dotPool[i].Visible=false end
end)

