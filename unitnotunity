task.spawn(function()
    while task.wait(0.5) do
        local count = entityCount
        ivEntC.Text = tostring(count)

        for model, data in pairs(entityCache) do
            -- refresh pp reference if it disappeared (e.g. model rebuilt)
            if not data.pp or not data.pp.Parent then
                data.pp = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
            end
            local pp = data.pp
            if not pp then continue end

            -- Entity ESP billboard (add if missing and flag on)
            if F.EntityESP and not model:FindFirstChild("UnitTag") then
                local bg=Instance.new("BillboardGui",model)
                bg.Name="UnitTag"; bg.AlwaysOnTop=true
                bg.Size=UDim2.new(0,136,0,42); bg.Adornee=pp
                local tl=Instance.new("TextLabel",bg)
                tl.BackgroundTransparency=1; tl.Size=UDim2.new(1,0,1,0)
                tl.TextColor3=Color3.fromRGB(255,68,68)
                tl.Font=Enum.Font.GothamBold; tl.TextSize=11
                tl.TextStrokeTransparency=0.14; tl.RichText=true
                task.spawn(function()
                    -- throttled at 0.3s — was 0.15s, halves coroutine load
                    while model.Parent~=nil and F.EntityESP do
                        local hrp=getHRP()
                        if hrp then
                            local dist=math.floor((hrp.Position-pp.Position).Magnitude)
                            tl.Text="<b>"..model.Name.."</b>\n<font size=\"10\">"..dist.." studs</font>"
                        end
                        task.wait(0.3)
                    end
                    pcall(function() bg:Destroy() end)
                end)
            end

            -- Chams (add if missing and flag on)
            if F.EntityChams and not model:FindFirstChild("ChamsHL") then
                local h=Instance.new("Highlight",model)
                h.Name="ChamsHL"; h.FillColor=Color3.fromRGB(88,0,208)
                h.OutlineColor=Color3.fromRGB(162,68,255); h.FillTransparency=0.35
                task.spawn(function()
                    while model.Parent~=nil and F.EntityChams do task.wait(0.5) end
                    pcall(function() h:Destroy() end)
                end)
            end
        end
    end
end)

-- ================================================================
--  IMAGE-ENTITY ALERT SCANNER
--  Iterates entityCache only — small table, no workspace scan.
--  Runs every 0.6s (was 0.4s scanning all of workspace).
-- ================================================================
task.spawn(function()
    while task.wait(0.6) do
        if not F.ImageAlert then
            ivImgEnt.Text="alerts off"; ivImgEnt.TextColor3=W.txtHint; continue
        end
        local hrp=getHRP(); if not hrp then continue end
        local selfPos=hrp.Position

        local nearestDist=math.huge
        local nearestEntry=nil

        for model, data in pairs(entityCache) do
            local entry=matchImageEntity(model.Name)
            if entry then
                local pp=data.pp
                if pp then
                    local dist=(selfPos-pp.Position).Magnitude
                    if dist<nearestDist then nearestDist=dist; nearestEntry=entry end
                    if dist<=ALERT_RANGE then
                        local now=tick()
                        if now-(imageEntityAlerted[entry.pattern] or 0)>8 then
                            imageEntityAlerted[entry.pattern]=now
                            showAlert(entry.label, dist, entry.color)
                            notify("⚠ "..entry.label.." — "..math.floor(dist).." studs", entry.color)
                        end
                    end
                end
            end
        end

        if nearestEntry then
            ivImgEnt.Text=nearestEntry.label.."  "..math.floor(nearestDist).." st"
            ivImgEnt.TextColor3=nearestDist<=ALERT_RANGE and W.danger or W.warn
        else
            ivImgEnt.Text="none detected"; ivImgEnt.TextColor3=W.txtSec
        end
    end
end)

