local alertActive=false
local alertHideTask=nil

local function showAlert(label, dist, color)
    AlertBanner.BackgroundColor3 = Color3.fromRGB(
        math.floor(color.R*255*0.55), math.floor(color.G*255*0.25), math.floor(color.B*255*0.25)
    )
    AlertStroke.Color = color
    AlertGrad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(
            math.min(255, math.floor(color.R*255*0.7)),
            math.min(255, math.floor(color.G*255*0.35)),
            math.min(255, math.floor(color.B*255*0.35))
        )),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(
            math.min(255, math.floor(color.R*255*0.4)),
            math.min(255, math.floor(color.G*255*0.2)),
            math.min(255, math.floor(color.B*255*0.2))
        )),
    }
    AlertTitle.Text = "⚠  " .. label .. " NEARBY"
    AlertTitle.TextColor3 = color
    AlertSub.Text = "Image entity  ·  " .. math.floor(dist) .. " studs away"

    if not alertActive then
        alertActive = true
        AlertBanner.Visible = true
        tw(AlertBanner, 0.22, {Position=UDim2.new(0.5,-170,0,14)})
    end

    -- pulse the stroke
    task.spawn(function()
        for _ = 1, 3 do
            tw(AlertStroke, 0.18, {Transparency=0.7})
            task.wait(0.22)
            tw(AlertStroke, 0.18, {Transparency=0})
            task.wait(0.22)
        end
    end)

    if alertHideTask then task.cancel(alertHideTask) end
    alertHideTask = task.delay(5, function()
        tw(AlertBanner, 0.22, {Position=UDim2.new(0.5,-170,-0.2,0)})
        task.wait(0.28)
        AlertBanner.Visible = false
        alertActive = false
        alertHideTask = nil
    end)
end

