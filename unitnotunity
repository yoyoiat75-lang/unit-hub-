actbtn(UTP,"Run Once","Pathfind to nearest scrap once (no loop)","Run",W.teal,function()
    if pfActive then notify("Already running", W.warn); return end
    local hum=getHum(); local hrp=getHRP()
    if not hum or not hrp then notify("No character", W.danger); return end
    task.spawn(function()
        local target = findBestScrap(hrp.Position, nil)
        if not target then notify("No scrap found",W.danger); return end
        if entityNear(target.pos, PATH_BLOCK) then notify("Entity blocking scrap path",W.warn); return end
        local path=PFS:CreatePath(PF_AGENT_PARAMS)
        local ok=pcall(function() path:ComputeAsync(hrp.Position,target.pos) end)
        if not ok or path.Status==Enum.PathStatus.NoPath then notify("No path to scrap",W.danger); return end
        hum.WalkSpeed=SPRINT_SPEED; local t0=tick(); local sprintMax=F.SprintDuration
        for _,wp in ipairs(path:GetWaypoints()) do
            hrp=getHRP(); hum=getHum(); if not hrp or not hum then break end
            if entityNear(hrp.Position, FLEE_TRIGGER) then hum:MoveTo(hrp.Position); notify("Entity nearby — aborted",W.warn); break end
            if tick()-t0>=sprintMax then hum.WalkSpeed=F.OrigSpeed*F.SpeedMult end
            if wp.Action==Enum.PathWaypointAction.Jump then hum.Jump=true end
            hum:MoveTo(wp.Position); hum.MoveToFinished:Wait()
        end
        if hum then hum.WalkSpeed=F.OrigSpeed*F.SpeedMult end
        notify("Reached scrap ("..math.floor(target.dist).." st)",W.success)
    end)
end)

