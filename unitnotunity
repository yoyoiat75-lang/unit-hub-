local notifQ={}; local notifBusy=false
local function notify(msg, color)
    table.insert(notifQ,{msg=msg, col=color or Color3.fromRGB(196,224,255)})
    if notifBusy then return end
    notifBusy=true
    task.spawn(function()
        while #notifQ>0 do
            local n=table.remove(notifQ,1)
            NotifTxt.Text="  "..n.msg; NotifTxt.TextColor3=n.col
