local function tw(obj, t, props)
    TS:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end
local function getChar() return LP.Character end
local function getHRP()  local c=getChar(); return c and c:FindFirstChild("HumanoidRootPart") end
local function getHum()  local c=getChar(); return c and c:FindFirstChildOfClass("Humanoid") end

local function getCurrentMap()
    local mf=workspace:FindFirstChild("MapFolder")
    local mn=mf and mf:FindFirstChild("Main"); if not mn then return nil end
    for _,ch in ipairs(mn:GetChildren()) do
        if ch:IsA("Model") or ch:IsA("Folder") then return ch end
    end
end

local function getSpawnParts()
    local map=getCurrentMap(); if not map then return {} end
    local sf=map:FindFirstChild("Spawns")
    if not sf then
        for _,d in ipairs(map:GetDescendants()) do
            if (d:IsA("Folder") or d:IsA("Model")) and d.Name:lower()=="spawns" then sf=d; break end
        end
    end
    if not sf then return {} end
    local out={}
    for _,s in ipairs(sf:GetChildren()) do
        if s:IsA("BasePart") or s:IsA("SpawnLocation") then table.insert(out,s) end
    end
    return out
end

local function doSafeTeleport()
    local hrp=getHRP(); if not hrp then return false,"no HRP" end
    local parts=getSpawnParts(); if #parts==0 then return false,"no spawn parts" end
    local nearest,nd=nil,math.huge
    for _,sp in ipairs(parts) do
        local d=(hrp.Position-sp.Position).Magnitude; if d<nd then nd=d; nearest=sp end
    end
    if not nearest then return false,"no nearest" end
    local wa=hrp.Anchored; hrp.Anchored=true
    hrp.CFrame=nearest.CFrame+Vector3.new(0,5,0); task.wait(0.1); hrp.Anchored=wa
    return true,"ok"
end

local function applySpeed()
    local h=getHum(); if h then h.WalkSpeed=F.OrigSpeed*F.SpeedMult end
end

-- ================================================================
--  ENTITY CACHE  ← event-driven, no per-frame GetDescendants
--
--  Instead of calling ef:GetDescendants() every 0.5s (which locks the
--  main thread while Luau traverses the whole tree), we keep a live
--  set by connecting to DescendantAdded / DescendantRemoving once.
--  The ESP / chams / alert logic then just iterates this small table.
-- ================================================================
local entityCache  = {}   -- [model] = {pp=BasePart, name=string}
local entityCount  = 0

local function cacheAdd(d)
    if not d:IsA("Model") then return end
    if entityCache[d] then return end
    local pp = d.PrimaryPart or d:FindFirstChildWhichIsA("BasePart")
    entityCache[d] = { pp=pp, name=d.Name }
    entityCount += 1
end

local function cacheRemove(d)
    if entityCache[d] then
        entityCache[d] = nil
        entityCount = math.max(0, entityCount-1)
    end
end

-- Connect to Entities folder when it appears
local entitiesFolder = workspace:FindFirstChild("Entities")

local function hookEntitiesFolder(ef)
    if not ef then return end
    -- seed existing
    for _,d in ipairs(ef:GetDescendants()) do cacheAdd(d) end
    ef.DescendantAdded:Connect(cacheAdd)
    ef.DescendantRemoving:Connect(cacheRemove)
end

hookEntitiesFolder(entitiesFolder)
if not entitiesFolder then
    workspace.ChildAdded:Connect(function(c)
        if c.Name=="Entities" then hookEntitiesFolder(c) end
    end)
end

-- ================================================================
--  SCRAP / CORPSE CACHES (same pattern — event-driven)
-- ================================================================
local scrapCache   = {}
local corpseCache  = {}

local function hookFolder(folder, cache)
    if not folder then return end
    local function add(d)
        if (d:IsA("Model") or d:IsA("BasePart")) and not cache[d] then
            cache[d] = true
        end
    end
    local function rem(d) cache[d] = nil end
    for _,d in ipairs(folder:GetDescendants()) do add(d) end
    folder.DescendantAdded:Connect(add)
    folder.DescendantRemoving:Connect(rem)
end

local function tryHookScrap()
    local dm = workspace:FindFirstChild("Debris") and workspace.Debris:FindFirstChild("Map")
    if dm then hookFolder(dm, scrapCache) end
end
local function tryHookCorpse()
    local ch = workspace:FindFirstChild("Characters")
    if ch then
        local pc = ch:FindFirstChild("PlayerCorpses")
        if pc then hookFolder(pc, corpseCache) end
        ch.ChildAdded:Connect(function(c)
            if c.Name=="PlayerCorpses" then hookFolder(c, corpseCache) end
        end)
    end
end

tryHookScrap(); tryHookCorpse()
workspace.ChildAdded:Connect(function(c)
    if c.Name=="Debris" then
        c.ChildAdded:Connect(function(cc) if cc.Name=="Map" then hookFolder(cc, scrapCache) end end)
    elseif c.Name=="Characters" then
        c.ChildAdded:Connect(function(cc) if cc.Name=="PlayerCorpses" then hookFolder(cc, corpseCache) end end)
    end
end)

