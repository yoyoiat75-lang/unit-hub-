    task.spawn(function()
        for _=1,2 do tw(AStroke,0.15,{Transparency=0.75}); task.wait(0.2); tw(AStroke,0.15,{Transparency=0}); task.wait(0.2) end
    end)
    if alertHideTask then task.cancel(alertHideTask) end
