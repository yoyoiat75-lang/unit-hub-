    Instance.new("UICorner",hov).CornerRadius=UDim.new(0,8)

    local ll=Instance.new("TextLabel",row)
    ll.Size=UDim2.new(1,-68,0,20); ll.Position=UDim2.new(0,13,0,9)
    ll.BackgroundTransparency=1; ll.Text=label
    ll.TextColor3=broken and W.warn or W.txtPri
    ll.Font=Enum.Font.GothamSemibold; ll.TextSize=12; ll.TextXAlignment=Enum.TextXAlignment.Left; ll.ZIndex=2

    local dl=Instance.new("TextLabel",row)
    dl.Size=UDim2.new(1,-68,0,14); dl.Position=UDim2.new(0,13,0,30)
    dl.BackgroundTransparency=1; dl.Text=desc
    dl.TextColor3=W.txtHint; dl.Font=Enum.Font.Gotham; dl.TextSize=10
    dl.TextXAlignment=Enum.TextXAlignment.Left; dl.ZIndex=2

    local track=Instance.new("Frame",row)
    track.Size=UDim2.new(0,38,0,20); track.Position=UDim2.new(1,-50,0.5,-10)
    track.BackgroundColor3=W.pillOff; track.BorderSizePixel=0; track.ZIndex=3
    Instance.new("UICorner",track).CornerRadius=UDim.new(1,0)
    local trkS=Instance.new("UIStroke",track); trkS.Color=Color3.fromRGB(84,84,108); trkS.Thickness=1

    local thumb=Instance.new("Frame",track)
    thumb.Size=UDim2.new(0,14,0,14); thumb.Position=UDim2.new(0,3,0.5,-7)
    thumb.BackgroundColor3=Color3.fromRGB(172,172,195); thumb.BorderSizePixel=0; thumb.ZIndex=4
    Instance.new("UICorner",thumb).CornerRadius=UDim.new(1,0)

    local active=false
    local function setState(v)
        active=v
        if v then
            tw(track,0.16,{BackgroundColor3=W.accent}); tw(trkS,0.16,{Color=W.accentHov})
            tw(thumb,0.16,{Position=UDim2.new(0,21,0.5,-7),BackgroundColor3=Color3.new(1,1,1)})
            tw(rs,0.16,{Color=W.accent}); tw(row,0.16,{BackgroundColor3=Color3.fromRGB(12,16,38)})
        else
            tw(track,0.16,{BackgroundColor3=W.pillOff}); tw(trkS,0.16,{Color=Color3.fromRGB(84,84,108)})
            tw(thumb,0.16,{Position=UDim2.new(0,3,0.5,-7),BackgroundColor3=Color3.fromRGB(172,172,195)})
            tw(rs,0.16,{Color=W.sep}); tw(row,0.16,{BackgroundColor3=W.surface})
        end
    end

    local hb=Instance.new("TextButton",row)
    hb.Size=UDim2.new(1,0,1,0); hb.BackgroundTransparency=1; hb.Text=""; hb.ZIndex=10
    hb.MouseEnter:Connect(function() tw(hov,0.1,{BackgroundTransparency=0.94,BackgroundColor3=Color3.new(1,1,1)}) end)
    hb.MouseLeave:Connect(function() tw(hov,0.1,{BackgroundTransparency=1}) end)
    hb.MouseButton1Click:Connect(function() setState(not active); cb(active) end)
    return setState
end

local function sld(page,label,desc,minV,maxV,def,cb)
    local row=Instance.new("Frame",page)
    row.Size=UDim2.new(1,0,0,62); row.BackgroundColor3=W.surface; row.BorderSizePixel=0
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,8)
    Instance.new("UIStroke",row).Color=W.sep

    local ll=Instance.new("TextLabel",row)
    ll.Size=UDim2.new(0.62,0,0,18); ll.Position=UDim2.new(0,13,0,8)
    ll.BackgroundTransparency=1; ll.Text=label
    ll.TextColor3=W.txtPri; ll.Font=Enum.Font.GothamSemibold; ll.TextSize=12
    ll.TextXAlignment=Enum.TextXAlignment.Left

    local vl=Instance.new("TextLabel",row)
    vl.Size=UDim2.new(0.34,0,0,18); vl.Position=UDim2.new(0.64,0,0,8)
    vl.BackgroundTransparency=1; vl.Text=tostring(def)
    vl.TextColor3=W.accent; vl.Font=Enum.Font.GothamBold; vl.TextSize=12
    vl.TextXAlignment=Enum.TextXAlignment.Right

    if desc~="" then
        local dl=Instance.new("TextLabel",row)
        dl.Size=UDim2.new(1,-26,0,12); dl.Position=UDim2.new(0,13,0,26)
        dl.BackgroundTransparency=1; dl.Text=desc
        dl.TextColor3=W.txtHint; dl.Font=Enum.Font.Gotham; dl.TextSize=9
        dl.TextXAlignment=Enum.TextXAlignment.Left
    end

    local trk=Instance.new("Frame",row)
    trk.Size=UDim2.new(1,-26,0,4); trk.Position=UDim2.new(0,13,1,-14)
    trk.BackgroundColor3=W.sep; trk.BorderSizePixel=0
    Instance.new("UICorner",trk).CornerRadius=UDim.new(1,0)

    local fill=Instance.new("Frame",trk)
    fill.Size=UDim2.new((def-minV)/(maxV-minV),0,1,0)
    fill.BackgroundColor3=W.accent; fill.BorderSizePixel=0
    Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)
    Instance.new("UIGradient",fill).Color=ColorSequence.new{
        ColorSequenceKeypoint.new(0,W.accent), ColorSequenceKeypoint.new(1,W.accentPurp)
    }

    local dot=Instance.new("Frame",trk)
    dot.Size=UDim2.new(0,12,0,12); dot.AnchorPoint=Vector2.new(0.5,0.5)
    dot.Position=UDim2.new((def-minV)/(maxV-minV),0,0.5,0)
    dot.BackgroundColor3=Color3.new(1,1,1); dot.BorderSizePixel=0; dot.ZIndex=3
    Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0)
    local dotS=Instance.new("UIStroke",dot); dotS.Color=W.accent; dotS.Thickness=1.5

    local dragging=false
    local hb=Instance.new("TextButton",trk)
    hb.Size=UDim2.new(1,0,0,26); hb.Position=UDim2.new(0,0,0.5,-13)
    hb.BackgroundTransparency=1; hb.Text=""; hb.ZIndex=10
    local function upd(mx)
        local t=math.clamp((mx-trk.AbsolutePosition.X)/trk.AbsoluteSize.X,0,1)
        local v=math.floor(minV+t*(maxV-minV))
        fill.Size=UDim2.new(t,0,1,0); dot.Position=UDim2.new(t,0,0.5,0)
        vl.Text=tostring(v); cb(v)
    end
    hb.MouseButton1Down:Connect(function() dragging=true; tw(dot,0.1,{Size=UDim2.new(0,16,0,16)}) end)
    UIS.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=false; tw(dot,0.1,{Size=UDim2.new(0,12,0,12)})
        end
    end)
    RS.Heartbeat:Connect(function() if dragging then upd(UIS:GetMouseLocation().X) end end)
    hb.MouseButton1Click:Connect(function() upd(UIS:GetMouseLocation().X) end)
end

