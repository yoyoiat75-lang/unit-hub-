-- ================================================================
--  IMAGE-ENTITY PROXIMITY SCANNER
--  Scans workspace (Entities folder + root) for BillboardGuis or
--  ImageLabels that match known 2D-entity names.
--  Also scans Models named after known entities regardless of content
--  (the billboard might be inside a Model wrapper).
--  Alert threshold: 80 studs (they are dangerous up close).
-- ================================================================
local ALERT_RANGE = 80  -- studs

task.spawn(function()
    while task.wait(0.4) do
        if not F.ImageAlert then
            ivImgEnt.Text = "alerts off"
            continue
        end

        local hrp = getHRP()
        if not hrp then continue end
        local selfPos = hrp.Position

        local nearbyCount = 0
        local closestDist = math.huge
        local closestEntry = nil

        -- Scan workspace root AND Entities folder
        local scanRoots = {workspace}
        local ef = workspace:FindFirstChild("Entities")
        if ef then table.insert(scanRoots, ef) end

        local checkedNames = {}

        for _, root in ipairs(scanRoots) do
            for _, obj in ipairs(root:GetDescendants()) do
                -- Check models/parts by name
                if obj:IsA("Model") or obj:IsA("BasePart") or obj:IsA("BillboardGui") then
                    local entry = matchImageEntity(obj.Name)
                    if entry and not checkedNames[entry.pattern] then
                        -- Get position
                        local pos
                        if obj:IsA("Model") then
                            local pp = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                            if pp then pos = pp.Position end
                        elseif obj:IsA("BasePart") then
                            pos = obj.Position
                        elseif obj:IsA("BillboardGui") and obj.Adornee and obj.Adornee:IsA("BasePart") then
                            pos = obj.Adornee.Position
                        elseif obj:IsA("BillboardGui") then
                            local p = obj.Parent
                            if p and p:IsA("BasePart") then pos = p.Position end
                        end

                        if pos then
                            local dist = (selfPos - pos).Magnitude
                            nearbyCount += 1
                            if dist < closestDist then
                                closestDist = dist
                                closestEntry = {entry=entry, dist=dist}
                            end
                            -- only show one alert per pattern per 8s
                            if dist <= ALERT_RANGE then
                                local now = tick()
                                local lastAlert = imageEntityAlerted[entry.pattern] or 0
                                if now - lastAlert > 8 then
                                    imageEntityAlerted[entry.pattern] = now
                                    showAlert(entry.label, dist, entry.color)
                                    notify("⚠ "..entry.label.." detected — "..math.floor(dist).." studs", entry.color)
                                end
                                checkedNames[entry.pattern] = true
                            end
                        end
                    end
                end
            end
        end

        if nearbyCount > 0 and closestEntry then
            ivImgEnt.Text = nearbyCount.." found  ·  "..math.floor(closestEntry.dist).." st"
            ivImgEnt.TextColor3 = closestEntry.dist <= ALERT_RANGE and W.danger or W.warn
        else
            ivImgEnt.Text = "none detected"
            ivImgEnt.TextColor3 = W.txtSec
        end
    end
end)

