    Instance.new("UICorner",ab).CornerRadius=UDim.new(0,6)
    ab.MouseEnter:Connect(function() tw(ab,0.1,{BackgroundColor3=Color3.fromRGB(math.min(255,c.R*255+16),math.min(255,c.G*255+16),math.min(255,c.B*255+16))}) end)
    ab.MouseLeave:Connect(function() tw(ab,0.1,{BackgroundColor3=c}) end)
    ab.MouseButton1Click:Connect(function()
        tw(ab,0.07,{BackgroundColor3=cD})
        task.delay(0.16,function() tw(ab,0.12,{BackgroundColor3=c}) end)
        cb()
    end)
