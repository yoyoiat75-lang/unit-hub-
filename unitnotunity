local function newPage()
    local sf=Instance.new("ScrollingFrame",CA)
    sf.Size=UDim2.new(1,0,1,0); sf.BackgroundTransparency=1
    sf.BorderSizePixel=0; sf.ScrollBarThickness=2
    sf.ScrollBarImageColor3=W.accent
    sf.CanvasSize=UDim2.new(0,0,0,0); sf.AutomaticCanvasSize=Enum.AutomaticSize.Y
    sf.Visible=false
    local pad=Instance.new("UIPadding",sf)
    pad.PaddingLeft=UDim.new(0,12); pad.PaddingRight=UDim.new(0,12)
    pad.PaddingTop=UDim.new(0,10); pad.PaddingBottom=UDim.new(0,14)
    local ll=Instance.new("UIListLayout",sf)
    ll.Padding=UDim.new(0,7); ll.HorizontalAlignment=Enum.HorizontalAlignment.Center
    ll.SortOrder=Enum.SortOrder.LayoutOrder
    return sf
end

local function switchTab(name)
    if activeN==name then return end
    activeN=name
    for _,t in ipairs(tabs) do
        local on=t.n==name
        t.page.Visible=on
        tw(t.btn,0.12,{TextColor3=on and W.txtPri or W.txtHint})
        tw(t.ind,0.12,{BackgroundTransparency=on and 0 or 1})
    end
end

for _,d in ipairs(TDEFS) do
    local page=newPage()
    local btn=Instance.new("TextButton",TabBar)
    btn.Size=UDim2.new(0,d.w,0,34); btn.BackgroundTransparency=1
    btn.BorderSizePixel=0; btn.Text=d.n; btn.TextColor3=W.txtHint
    btn.Font=Enum.Font.GothamSemibold; btn.TextSize=10; btn.AutoButtonColor=false; btn.ZIndex=3
    local ind=Instance.new("Frame",btn)
    ind.Size=UDim2.new(0.68,0,0,2); ind.Position=UDim2.new(0.16,0,1,-2)
    ind.BackgroundColor3=W.accent; ind.BorderSizePixel=0; ind.BackgroundTransparency=1; ind.ZIndex=4
    Instance.new("UIGradient",ind).Color=ColorSequence.new{
        ColorSequenceKeypoint.new(0,W.accent), ColorSequenceKeypoint.new(1,W.accentPurp)
    }
    Instance.new("UICorner",ind).CornerRadius=UDim.new(1,0)
    btn.MouseEnter:Connect(function() if activeN~=d.n then tw(btn,0.1,{TextColor3=W.txtSec}) end end)
    btn.MouseLeave:Connect(function() if activeN~=d.n then tw(btn,0.1,{TextColor3=W.txtHint}) end end)
