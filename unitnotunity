local pfActive   = false
local pfThread   = nil

local WALK_SPEED     = 16
local SPRINT_SPEED   = 22
local FLEE_SPEED     = 26

local STAMINA_MAX      = 12
local STAMINA_DRAIN    = 1.0
local STAMINA_REGEN    = 1.0
local STAMINA_REGEN_FAST = 2.0
local stamina          = STAMINA_MAX
local lastStaminaTick  = tick()

local function updateStamina(isSprinting, entityFar)
    local now  = tick()
    local dt   = now - lastStaminaTick
    lastStaminaTick = now
    if isSprinting then
        stamina = math.max(0, stamina - STAMINA_DRAIN * dt)
    else
        local rate = entityFar and STAMINA_REGEN_FAST or STAMINA_REGEN
        stamina = math.min(STAMINA_MAX, stamina + rate * dt)
    end
    return stamina
end

local FLEE_TRIGGER     = 22
local SPRINT_TRIGGER   = 45
local PATH_BLOCK       = 14
local ENTITY_SEE_RANGE = 180
local COMBAT_FLEE_TIME = 5.0
local FLEE_DIST        = 55

local JUMP_HEIGHT_MIN  = 1.8
local STUCK_TIME       = 0.75
local STUCK_DIST       = 1.2

local STATE_SCRAP   = "SCRAP"
local STATE_COMBAT  = "COMBAT"
local STATE_FLEE    = "FLEE"
local pfState       = STATE_SCRAP

local visitedScraps = {}
local lastHP        = math.huge

local ivPFStatus
local ivPFSprint

local function nearestEntity(fromPos)
    local bestPos, bestDist = nil, math.huge
    for _, data in pairs(entityCache) do
        if data.pp and data.pp.Parent then
            local d = (fromPos - data.pp.Position).Magnitude
            if d < bestDist then bestDist = d; bestPos = data.pp.Position end
        end
    end
    return bestPos, bestDist
end

local function entityNear(pos, radius)
    for _, data in pairs(entityCache) do
        if data.pp and data.pp.Parent then
            if (pos - data.pp.Position).Magnitude < radius then return true end
        end
    end
    return false
end

local PF_AGENT_PARAMS = {
    AgentHeight  = 5,
    AgentRadius  = 2,
    AgentCanJump = true,
    Costs        = { InteriorInvWall = 1000 },
}

local function findBestScrap(fromPos, avoidEntityRadius)
    local best, bestDist, bestPos = nil, math.huge, nil
    for obj in pairs(scrapCache) do
        if visitedScraps[obj] then continue end
        if not obj.Parent then continue end
        local pos
        if obj:IsA("BasePart") then
            pos = obj.Position
        elseif obj:IsA("Model") and obj.PrimaryPart then
            pos = obj.PrimaryPart.Position
        end
        if not pos then continue end
        if avoidEntityRadius and entityNear(pos, avoidEntityRadius) then continue end
        local d = (fromPos - pos).Magnitude
        if d < bestDist then bestDist = d; best = obj; bestPos = pos end
    end
    if best then return { obj = best, pos = bestPos, dist = bestDist } end
    return nil
end

local function getNearestSafeSpawn(fromPos)
    local parts = getSpawnParts()
    if #parts == 0 then return nil end
    local best, bestDist = nil, math.huge
    for _, sp in ipairs(parts) do
        local d = (fromPos - sp.Position).Magnitude
        if d < bestDist and not entityNear(sp.Position, 30) then
            bestDist = d; best = sp
        end
    end
    if not best then
        for _, sp in ipairs(parts) do
            local d = (fromPos - sp.Position).Magnitude
            if d < bestDist then bestDist = d; best = sp end
        end
    end
    return best, bestDist
end

local function computePath(from, to)
    local path = PFS:CreatePath(PF_AGENT_PARAMS)
    local ok   = pcall(function() path:ComputeAsync(from, to) end)
    if not ok or path.Status == Enum.PathStatus.NoPath then return nil end
    local wps = path:GetWaypoints()
    return (#wps > 0) and wps or nil
end

local function walkToWaypoint(hum, wp)
    local hrp = getHRP()
    if not hrp then return false end

    local heightDiff = wp.Position.Y - hrp.Position.Y
    if heightDiff > JUMP_HEIGHT_MIN or wp.Action == Enum.PathWaypointAction.Jump then
        hum.Jump = true
        task.wait(0.12)
    end

    hum:MoveTo(wp.Position)

    local lastPos    = hrp.Position
    local lastMoveAt = tick()
    local arrived    = false
    local conn = hum.MoveToFinished:Connect(function(r) arrived = r end)

    local t0 = tick()
    repeat
        task.wait(0.07)
        hrp = getHRP()
        if not hrp then conn:Disconnect(); return false end

        if (hrp.Position - wp.Position).Magnitude < 2.2 then
            arrived = true; break
        end

        local moved = (hrp.Position - lastPos).Magnitude
        if moved > STUCK_DIST then
            lastPos = hrp.Position; lastMoveAt = tick()
        elseif tick() - lastMoveAt > STUCK_TIME then
            hum.Jump   = true
            lastMoveAt = tick()
            lastPos    = hrp.Position
        end

        if not pfActive or not F.PathfindScrap then
            conn:Disconnect(); return false
        end
    until arrived or (tick() - t0 > 5)

    conn:Disconnect()
    return arrived
end

local function rawFlee(hum, duration, speed)
    hum.WalkSpeed = speed or FLEE_SPEED
    local t0 = tick()
    while tick() - t0 < duration do
        local hrp = getHRP()
        if not hrp or not hum then break end

        local tx, tz, n = 0, 0, 0
        for _, data in pairs(entityCache) do
            if data.pp and data.pp.Parent then
                local d = (hrp.Position - data.pp.Position).Magnitude
                if d < FLEE_TRIGGER * 4 then
                    tx += data.pp.Position.X
                    tz += data.pp.Position.Z
                    n  += 1
                end
            end
        end

        if n == 0 then break end

        local threat = Vector3.new(tx/n, hrp.Position.Y, tz/n)
        local away   = hrp.Position - threat
        away = Vector3.new(away.X, 0, away.Z)
        if away.Magnitude < 0.5 then
            away = Vector3.new(math.random()-0.5, 0, math.random()-0.5)
        end
        hum:MoveTo(hrp.Position + away.Unit * FLEE_DIST)
        task.wait(0.28)
    end
    local hrp = getHRP()
    if hrp and hum then hum:MoveTo(hrp.Position) end
end

local function smartFlee(hum, reason)
    if ivPFStatus then ivPFStatus.Text = "⚠ " .. (reason or "FLEE") .. " — heading to spawn" end
    if ivPFSprint  then ivPFSprint.Text = "COMBAT" end

    hum.WalkSpeed = FLEE_SPEED
    stamina = math.max(0, stamina)

    local hrp = getHRP()
    if not hrp then return end

    local spawn, _ = getNearestSafeSpawn(hrp.Position)
    if not spawn then
        rawFlee(hum, COMBAT_FLEE_TIME, FLEE_SPEED)
        return
    end

    local waypoints = computePath(hrp.Position, spawn.Position + Vector3.new(0, 3, 0))
    if not waypoints then
        if ivPFStatus then ivPFStatus.Text = "⚠ No path to spawn — raw flee" end
        rawFlee(hum, COMBAT_FLEE_TIME, FLEE_SPEED)
        return
    end

    local deadline = tick() + COMBAT_FLEE_TIME + 4
    for _, wp in ipairs(waypoints) do
        if tick() > deadline then break end
        if not pfActive or not F.PathfindScrap then break end

        hrp = getHRP(); hum = getHum()
        if not hrp or not hum then break end

        local _, eDist = nearestEntity(hrp.Position)
        hum.WalkSpeed = eDist < SPRINT_TRIGGER and FLEE_SPEED or SPRINT_SPEED

        walkToWaypoint(hum, wp)
    end

    if ivPFStatus then ivPFStatus.Text = "reached safety — resuming" end
    if ivPFSprint  then ivPFSprint.Text = "—" end
    task.wait(0.8)
end

local function stopPathfinding(reason)
    pfActive = false
    if pfThread then task.cancel(pfThread); pfThread = nil end
    local hum = getHum()
    if hum then hum.WalkSpeed = F.OrigSpeed * F.SpeedMult end
    if ivPFStatus then ivPFStatus.Text = reason or "idle" end
    if ivPFSprint  then ivPFSprint.Text = "—" end
end

local function runPathfindingLoop()
    pfActive      = true
    visitedScraps = {}
    pfState       = STATE_SCRAP
    lastStaminaTick = tick()

    local hum0 = getHum()
    lastHP = hum0 and math.floor(hum0.Health) or math.huge

    while F.PathfindScrap and pfActive do
        local hrp = getHRP()
        local hum = getHum()
        if not hrp or not hum then stopPathfinding("no char"); return end

        local selfPos = hrp.Position
        local _, eDist = nearestEntity(selfPos)

        local curHP = math.floor(hum.Health)
        if curHP < lastHP and curHP > 0 then
            pfState = STATE_COMBAT
            stamina = math.min(stamina + 3, STAMINA_MAX)
        end
        lastHP = curHP

        if pfState == STATE_COMBAT then
            if ivPFStatus then ivPFStatus.Text = "⚠ TAKING DAMAGE — fleeing!" end
            smartFlee(hum, "DAMAGE TAKEN")
            pfState = STATE_SCRAP
            lastHP  = math.floor((getHum() or {Health=math.huge}).Health)
            continue
        end

        if eDist < FLEE_TRIGGER then
            pfState = STATE_FLEE
            if ivPFStatus then ivPFStatus.Text = "⚠ Entity "..math.floor(eDist).." st — FLEE" end
            smartFlee(hum, "ENTITY "..math.floor(eDist).." st")
            pfState = STATE_SCRAP
            continue
        end

        pfState = STATE_SCRAP

        local target = findBestScrap(selfPos, PATH_BLOCK)
        if not target then
            visitedScraps = {}
            target = findBestScrap(selfPos, nil)
        end
        if not target then
            if ivPFStatus then ivPFStatus.Text = "no scrap found" end
            if ivPFSprint  then ivPFSprint.Text = "—" end
            task.wait(2); continue
        end

        visitedScraps[target.obj] = true
        if ivPFStatus then ivPFStatus.Text = "→ scrap  "..math.floor(target.dist).." st" end

        local waypoints = computePath(selfPos, target.pos)
        if not waypoints then
            if ivPFStatus then ivPFStatus.Text = "no path — skipping" end
            task.wait(0.8); continue
        end

        local aborted     = false
        local cdownActive = true

        task.spawn(function()
            while cdownActive and pfActive and F.PathfindScrap do
                local st = math.floor(stamina * 10) / 10
                if ivPFSprint then
                    ivPFSprint.Text = "stamina  "..string.format("%.1f", st).."s"
                end
                task.wait(0.1)
            end
            if ivPFSprint then ivPFSprint.Text = "—" end
        end)

        for _, wp in ipairs(waypoints) do
            if not F.PathfindScrap or not pfActive then aborted = true; break end

            hrp = getHRP(); hum = getHum()
            if not hrp or not hum then aborted = true; break end

            local midHP = math.floor(hum.Health)
            if midHP < lastHP and midHP > 0 then
                lastHP  = midHP
                pfState = STATE_COMBAT
                stamina = math.min(stamina + 3, STAMINA_MAX)
                hum:MoveTo(hrp.Position)
                cdownActive = false
                smartFlee(hum, "DAMAGE MID-PATH")
                pfState = STATE_SCRAP
                lastHP  = math.floor((getHum() or {Health=math.huge}).Health)
                aborted = true; break
            end
            lastHP = midHP

            local _, midEDist = nearestEntity(hrp.Position)
            if midEDist < FLEE_TRIGGER then
                hum:MoveTo(hrp.Position)
                cdownActive = false
                smartFlee(hum, "ENTITY MID-PATH")
                aborted = true; break
            end

            if entityNear(wp.Position, PATH_BLOCK) then
                if ivPFStatus then ivPFStatus.Text = "entity on waypoint — skip" end
                continue
            end

            local isSprinting = false
            if midEDist < SPRINT_TRIGGER and stamina > 0 then
                isSprinting   = true
                hum.WalkSpeed = SPRINT_SPEED
            else
                isSprinting   = false
                hum.WalkSpeed = WALK_SPEED
            end

            local entityFar = midEDist > SPRINT_TRIGGER * 2
            updateStamina(isSprinting, entityFar)

            walkToWaypoint(hum, wp)
        end

        cdownActive = false
        hum = getHum()
        if hum then hum.WalkSpeed = F.OrigSpeed * F.SpeedMult end

        if not aborted then task.wait(0.25) end
    end

    stopPathfinding("stopped")
end

