    ASub.TextColor3=Color3.fromRGB(math.min(255,math.floor(r*0.9+120)),math.min(255,math.floor(g*0.5+100)),math.min(255,math.floor(b*0.5+100)))
    if not alertShowing then
        alertShowing=true; AlertBanner.Visible=true
        tw(AlertBanner,0.20,{Position=UDim2.new(0.5,0,0,12)})
