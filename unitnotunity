-- ================================================================
--  IMAGE-ENTITY ALERT LIST
--  These entities are 2D billboard images (not 3D models) — they move
--  silently and are easy to miss with regular ESP.
--  When detected within a certain range, a full notification is fired.
-- ================================================================
local IMAGE_ENTITIES = {
    -- name pattern (case-insensitive match)  →  display label + danger color
    { pattern = "alex",        label = "ALEX",         color = Color3.fromRGB(220, 50,  50) },
    { pattern = "angrymunci",  label = "ANGRY MUNCI",  color = Color3.fromRGB(255, 120,  0) },
    { pattern = "munci",       label = "MUNCI",        color = Color3.fromRGB(255, 160, 30) },
    { pattern = "angry munci", label = "ANGRY MUNCI",  color = Color3.fromRGB(255, 120,  0) },
}
-- Deduplicate alert fire (prevent spam)
local imageEntityAlerted = {}   -- name → last alerted tick

local function matchImageEntity(name)
    local lower = name:lower():gsub("%s+","")
    for _, e in ipairs(IMAGE_ENTITIES) do
        local pat = e.pattern:gsub("%s+","")
        if lower:match(pat) then return e end
    end
    return nil
end

