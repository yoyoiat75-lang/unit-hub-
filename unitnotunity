-- ================================================================
local function tw(obj, t, props)
    TS:Create(obj, TweenInfo.new(t, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end
local function getChar() return LP.Character end
local function getHRP()  local c=getChar(); return c and c:FindFirstChild("HumanoidRootPart") end
local function getHum()  local c=getChar(); return c and c:FindFirstChildOfClass("Humanoid") end

local function getCurrentMap()
    local mf = workspace:FindFirstChild("MapFolder")
    local mn = mf and mf:FindFirstChild("Main"); if not mn then return nil end
    for _, ch in ipairs(mn:GetChildren()) do
        if ch:IsA("Model") or ch:IsA("Folder") then return ch end
    end
end

local function getSpawnParts()
    local map = getCurrentMap(); if not map then return {} end
    local sf = map:FindFirstChild("Spawns")
    if not sf then
        for _, d in ipairs(map:GetDescendants()) do
            if (d:IsA("Folder") or d:IsA("Model")) and d.Name:lower()=="spawns" then sf=d; break end
        end
    end
    if not sf then return {} end
    local out = {}
    for _, s in ipairs(sf:GetChildren()) do
        if s:IsA("BasePart") or s:IsA("SpawnLocation") then table.insert(out, s) end
    end
    return out
end

local function doSafeTeleport()
    local hrp = getHRP(); if not hrp then return false,"no HRP" end
    local parts = getSpawnParts(); if #parts==0 then return false,"no spawn parts" end
    local nearest, nd = nil, math.huge
    for _, sp in ipairs(parts) do
        local d = (hrp.Position-sp.Position).Magnitude
        if d<nd then nd=d; nearest=sp end
    end
    if not nearest then return false,"no nearest" end
    local wa = hrp.Anchored; hrp.Anchored = true
    hrp.CFrame = nearest.CFrame + Vector3.new(0,5,0)
    task.wait(0.1); hrp.Anchored = wa
    return true,"ok"
end

-- Speed application helper — always reads current F values
-- FIX v5.3: speed is now applied via a dedicated enforcer loop instead of
-- only on slider change.  The enforcer runs every 0.5s and clamps WalkSpeed
-- back to the intended value if the game resets it (e.g. on round restart,
-- after teleport, or after a server-side anti-cheat correction).
local function applySpeed()
    local h = getHum()
    if h then h.WalkSpeed = F.OrigSpeed * F.SpeedMult end
end

