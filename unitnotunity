local function changeEntry(page,ver,date,entries)
    local H=38+#entries*19+8
    local box=Instance.new("Frame",page)
    box.Size=UDim2.new(1,0,0,H); box.BackgroundColor3=W.surface; box.BorderSizePixel=0
    Instance.new("UICorner",box).CornerRadius=UDim.new(0,8)
    Instance.new("UIStroke",box).Color=W.sep
    local vb=Instance.new("Frame",box)
    vb.Size=UDim2.new(0,46,0,18); vb.Position=UDim2.new(0,12,0,11); vb.BorderSizePixel=0
    Instance.new("UICorner",vb).CornerRadius=UDim.new(0,4)
    local vbG=Instance.new("UIGradient",vb)
    vbG.Color=ColorSequence.new{ColorSequenceKeypoint.new(0,W.accent),ColorSequenceKeypoint.new(1,W.accentPurp)}
    local vl=Instance.new("TextLabel",vb)
    vl.Size=UDim2.new(1,0,1,0); vl.BackgroundTransparency=1; vl.Text=ver
    vl.TextColor3=Color3.new(1,1,1); vl.Font=Enum.Font.GothamBlack; vl.TextSize=10
    local dl=Instance.new("TextLabel",box)
    dl.Size=UDim2.new(0,200,0,18); dl.Position=UDim2.new(0,66,0,11)
    dl.BackgroundTransparency=1; dl.Text=date; dl.TextColor3=W.txtHint
    dl.Font=Enum.Font.Gotham; dl.TextSize=10; dl.TextXAlignment=Enum.TextXAlignment.Left
    local TC={ADD=W.success,FIX=W.warn,CHANGE=W.accent,REMOVE=W.danger}
    for i,e in ipairs(entries) do
        local tag,msg=e[1],e[2]
        local tb=Instance.new("Frame",box)
        tb.Size=UDim2.new(0,44,0,13); tb.Position=UDim2.new(0,12,0,38+(i-1)*19)
        tb.BackgroundColor3=TC[tag] or W.txtHint; tb.BackgroundTransparency=0.75; tb.BorderSizePixel=0
        Instance.new("UICorner",tb).CornerRadius=UDim.new(0,3)
        local tl=Instance.new("TextLabel",tb)
        tl.Size=UDim2.new(1,0,1,0); tl.BackgroundTransparency=1; tl.Text=tag
        tl.TextColor3=TC[tag] or Color3.new(1,1,1); tl.Font=Enum.Font.GothamBold; tl.TextSize=8
        local ml=Instance.new("TextLabel",box)
        ml.Size=UDim2.new(1,-62,0,13); ml.Position=UDim2.new(0,60,0,38+(i-1)*19)
        ml.BackgroundTransparency=1; ml.Text=msg; ml.TextColor3=W.txtSec
        ml.Font=Enum.Font.Gotham; ml.TextSize=10; ml.TextXAlignment=Enum.TextXAlignment.Left
    end
end

