-- ================================================================
--  PATHFINDING SCRAP SYSTEM  (v5.6: longer sprint)
-- ================================================================
local pfActive     = false
local pfThread     = nil
local SPRINT_SPEED = 28    -- v5.6: was 24
local NORMAL_SPEED = 16

local function getEntityPositions()
    local positions = {}
    for model, data in pairs(entityCache) do
        if data.pp then table.insert(positions, data.pp.Position) end
    end
    return positions
end

local function getNearestScrap()
    local hrp = getHRP(); if not hrp then return nil end
    local debrisMap = workspace:FindFirstChild("Debris")
        and workspace.Debris:FindFirstChild("Map")
    if not debrisMap then return nil end
    local scrapFolder = debrisMap:FindFirstChild("Scrap")
    if not scrapFolder then return nil end

    local nearest, nearestDist = nil, math.huge
    for _, obj in ipairs(scrapFolder:GetDescendants()) do
        if obj:IsA("BasePart") or obj:IsA("Model") then
            local pos
            if obj:IsA("BasePart") then
                pos = obj.Position
            elseif obj:IsA("Model") and obj.PrimaryPart then
                pos = obj.PrimaryPart.Position
            end
            if pos then
                local d = (hrp.Position - pos).Magnitude
                if d < nearestDist then nearestDist = d; nearest = obj end
            end
        end
    end
    return nearest, nearestDist
end

local ENTITY_AVOID_RADIUS = 20
local function isTooCloseToEntity(pos)
    for model, data in pairs(entityCache) do
        if data.pp then
            if (pos - data.pp.Position).Magnitude < ENTITY_AVOID_RADIUS then
                return true
            end
        end
    end
    return false
end

local ivPFStatus    -- assigned after widget build
local ivPFSprint    -- NEW: sprint timer display label

local function stopPathfinding(reason)
    pfActive = false
    if pfThread then task.cancel(pfThread); pfThread = nil end
    local hum = getHum()
    if hum then hum.WalkSpeed = F.OrigSpeed * F.SpeedMult end
    if ivPFStatus then ivPFStatus.Text = reason or "idle" end
    if ivPFSprint then ivPFSprint.Text = "—" end
end

local function runPathfindingLoop()
    pfActive = true
    local hum = getHum()
    local hrp = getHRP()
    if not hum or not hrp then stopPathfinding("no char"); return end

    while F.PathfindScrap and pfActive do
        hrp = getHRP(); hum = getHum()
        if not hrp or not hum then stopPathfinding("no char"); break end

        if isTooCloseToEntity(hrp.Position) then
            if ivPFStatus then ivPFStatus.Text = "⚠ Entity near — waiting" end
            if ivPFSprint then ivPFSprint.Text = "—" end
            task.wait(1)
            continue
        end

        local target, dist = getNearestScrap()
        if not target then
            if ivPFStatus then ivPFStatus.Text = "no scrap found" end
            if ivPFSprint then ivPFSprint.Text = "—" end
            task.wait(2)
            continue
        end

        local targetPos
        if target:IsA("BasePart") then
            targetPos = target.Position
        elseif target:IsA("Model") and target.PrimaryPart then
            targetPos = target.PrimaryPart.Position
        else
            task.wait(0.5); continue
        end

        if isTooCloseToEntity(targetPos) then
            if ivPFStatus then ivPFStatus.Text = "⚠ Entity on path — skipping" end
            task.wait(1.5)
            continue
        end

        local agentParams = { AgentHeight = 5, AgentRadius = 2, AgentCanJump = true }
        local path = PFS:CreatePath(agentParams)
        local ok, err = pcall(function() path:ComputeAsync(hrp.Position, targetPos) end)

        if not ok or path.Status == Enum.PathStatus.NoPath then
            if ivPFStatus then ivPFStatus.Text = "no path — skipping" end
            task.wait(1)
            continue
        end

        local waypoints = path:GetWaypoints()
        if #waypoints == 0 then task.wait(0.5); continue end

        hum.WalkSpeed = SPRINT_SPEED
        local sprintStart = tick()
        local sprintMax   = F.SprintDuration   -- v5.6: use configurable value
        local sprintExpired = false

        if ivPFStatus then
            ivPFStatus.Text = "→ scrap  "..math.floor(dist).." st"
        end

        -- Sprint countdown ticker (runs alongside waypoint loop)
        local countdownActive = true
        task.spawn(function()
            while countdownActive and pfActive and F.PathfindScrap do
                local elapsed = tick() - sprintStart
                local remaining = math.max(0, sprintMax - elapsed)
                if ivPFSprint then
                    if remaining > 0 then
                        ivPFSprint.Text = "sprint  "..string.format("%.1f", remaining).."s"
                    else
                        ivPFSprint.Text = "walking"
                    end
                end
                task.wait(0.1)
            end
            if ivPFSprint then ivPFSprint.Text = "—" end
        end)

        for _, wp in ipairs(waypoints) do
            if not F.PathfindScrap or not pfActive then break end
            hrp = getHRP(); hum = getHum()
            if not hrp or not hum then break end

            if isTooCloseToEntity(hrp.Position) then
                hum:MoveTo(hrp.Position)
                if ivPFStatus then ivPFStatus.Text = "⚠ Entity mid-path — abort" end
                task.wait(2)
                break
            end

            if tick() - sprintStart >= sprintMax then
                hum.WalkSpeed = F.OrigSpeed * F.SpeedMult
                sprintExpired = true
            end

            if wp.Action == Enum.PathWaypointAction.Jump then hum.Jump = true end
            hum:MoveTo(wp.Position)
            local moved = hum.MoveToFinished:Wait()
            if not moved then break end
        end

        countdownActive = false
        if hum then hum.WalkSpeed = F.OrigSpeed * F.SpeedMult end
        task.wait(0.3)
    end

    stopPathfinding("stopped")
end

