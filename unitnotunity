task.spawn(function()
    while task.wait(0.6) do
        if not F.ImageAlert then
            ivImgEnt.Text="alerts off"; ivImgEnt.TextColor3=W.txtHint; continue
        end
        local hrp=getHRP(); if not hrp then continue end
        local selfPos=hrp.Position
        local nearestDist=math.huge; local nearestEntry=nil

        for model, data in pairs(entityCache) do
            local entry=matchImageEntity(model.Name)
            if entry then
                local pp=data.pp
                if pp then
                    local dist=(selfPos-pp.Position).Magnitude
                    if dist<nearestDist then nearestDist=dist; nearestEntry=entry end
                    if dist<=ALERT_RANGE then
                        local now=tick()
                        if now-(imageEntityAlerted[entry.pattern] or 0)>8 then
                            imageEntityAlerted[entry.pattern]=now
                            showAlert(entry.label, dist, entry.color)
                            notify("⚠ "..entry.label.."  "..math.floor(dist).." studs", entry.color)
                        end
                    end
                end
            end
        end

        if nearestEntry then
            ivImgEnt.Text=nearestEntry.label.."  "..math.floor(nearestDist).." st"
            ivImgEnt.TextColor3=nearestDist<=ALERT_RANGE and W.danger or W.warn
