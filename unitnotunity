-- ============================================================
-- FIX: Completely rewritten slider input handling for mobile.
--
-- Root causes of the original bug:
--   1. MouseButton1Down never fires on touch — InputBegan must be used
--      on mobile for the initial press detection.
--   2. UIS:GetTouchState() returns an array of InputObjects, not a
--      simple {Position=...} table. Indexing [1] on it gave nil, so
--      the X coordinate was always nil, causing the slider to snap
--      to the left edge (nil treated as 0).
--   3. The Heartbeat loop polled GetTouchState every frame but the
--      first touch that started the drag was already consumed, so
--      subsequent frames saw a stale or empty table.
--
-- Fix strategy:
--   • On mobile, bind InputBegan on the hit button to start dragging
--     and record the active InputObject directly.
--   • Track the live position through UIS.InputChanged, comparing
--     the UserInputType to match only the touch/mouse that started
--     the drag.
--   • On InputEnded for that same input, clear the drag state.
--   • Desktop path (MouseButton1Down / Heartbeat mouse poll) is
--     kept exactly as before so nothing regresses on PC.
-- ============================================================
local function sld(page, label, desc, minV, maxV, def, cb)
    local SLD_H = IS_MOBILE and sp(68) or sp(62)
    local row=Instance.new("Frame",page)
    row.Size=UDim2.new(1,0,0,SLD_H); row.BackgroundColor3=W.surface; row.BorderSizePixel=0
    Instance.new("UICorner",row).CornerRadius=UDim.new(0,8)
    Instance.new("UIStroke",row).Color=W.sep

    local ll=Instance.new("TextLabel",row)
    ll.Size=UDim2.new(0.62,0,0,sp(18)); ll.Position=UDim2.new(0,sp(13),0,sp(8))
    ll.BackgroundTransparency=1; ll.Text=label
    ll.TextColor3=W.txtPri; ll.Font=Enum.Font.GothamSemibold; ll.TextSize=IS_MOBILE and 11 or 12
    ll.TextXAlignment=Enum.TextXAlignment.Left

    local vl=Instance.new("TextLabel",row)
    vl.Size=UDim2.new(0.34,0,0,sp(18)); vl.Position=UDim2.new(0.64,0,0,sp(8))
    vl.BackgroundTransparency=1; vl.Text=tostring(def)
    vl.TextColor3=W.accent; vl.Font=Enum.Font.GothamBold; vl.TextSize=IS_MOBILE and 11 or 12
    vl.TextXAlignment=Enum.TextXAlignment.Right

    if desc~="" then
        local dl=Instance.new("TextLabel",row)
        dl.Size=UDim2.new(1,-sp(26),0,sp(12)); dl.Position=UDim2.new(0,sp(13),0,sp(26))
        dl.BackgroundTransparency=1; dl.Text=desc
        dl.TextColor3=W.txtHint; dl.Font=Enum.Font.Gotham; dl.TextSize=IS_MOBILE and 8 or 9
        dl.TextXAlignment=Enum.TextXAlignment.Left
    end

    local trk=Instance.new("Frame",row)
    trk.Size=UDim2.new(1,-sp(26),0,IS_MOBILE and 6 or 4); trk.Position=UDim2.new(0,sp(13),1,-sp(14))
    trk.BackgroundColor3=W.sep; trk.BorderSizePixel=0
    Instance.new("UICorner",trk).CornerRadius=UDim.new(1,0)

    local fill=Instance.new("Frame",trk)
    fill.Size=UDim2.new((def-minV)/(maxV-minV),0,1,0)
    fill.BackgroundColor3=W.accent; fill.BorderSizePixel=0
    Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)
    Instance.new("UIGradient",fill).Color=ColorSequence.new{
        ColorSequenceKeypoint.new(0,W.accent), ColorSequenceKeypoint.new(1,W.accentPurp)
    }

    local DOT_S = IS_MOBILE and 16 or 12
    local dot=Instance.new("Frame",trk)
    dot.Size=UDim2.new(0,DOT_S,0,DOT_S); dot.AnchorPoint=Vector2.new(0.5,0.5)
    dot.Position=UDim2.new((def-minV)/(maxV-minV),0,0.5,0)
    dot.BackgroundColor3=Color3.new(1,1,1); dot.BorderSizePixel=0; dot.ZIndex=3
    Instance.new("UICorner",dot).CornerRadius=UDim.new(1,0)
    local dotS=Instance.new("UIStroke",dot); dotS.Color=W.accent; dotS.Thickness=1.5

    -- Shared update function: given a screen X, compute and apply value
    local function upd(screenX)
        local trkAbsX  = trk.AbsolutePosition.X
        local trkAbsW  = trk.AbsoluteSize.X
        local t = math.clamp((screenX - trkAbsX) / trkAbsW, 0, 1)
        local v = math.floor(minV + t * (maxV - minV))
        fill.Size       = UDim2.new(t, 0, 1, 0)
        dot.Position    = UDim2.new(t, 0, 0.5, 0)
        vl.Text         = tostring(v)
        cb(v)
    end

    -- Enlarged invisible hit region so the whole row area is draggable
    local HIT_PAD = IS_MOBILE and 22 or 13
    local hb = Instance.new("TextButton", trk)
    hb.Size              = UDim2.new(1, 0, 0, HIT_PAD * 2)
    hb.Position          = UDim2.new(0, 0, 0.5, -HIT_PAD)
    hb.BackgroundTransparency = 1
    hb.Text              = ""
    hb.ZIndex            = 10

    local dragging        = false
    local activeInputObj  = nil   -- FIX: track the specific InputObject

    if IS_MOBILE then
        -- FIX: Use InputBegan to capture the touch InputObject directly,
        -- then track it in InputChanged and release in InputEnded.
        hb.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch then
                dragging       = true
                activeInputObj = input
                tw(dot, 0.1, {Size = UDim2.new(0, DOT_S+5, 0, DOT_S+5)})
                upd(input.Position.X)
            end
        end)

        -- FIX: InputChanged fires every frame a touch moves; we read the
        -- position directly from the InputObject captured above.
        UIS.InputChanged:Connect(function(input)
            if dragging and activeInputObj and input == activeInputObj then
                upd(input.Position.X)
            end
        end)

        UIS.InputEnded:Connect(function(input)
            if input == activeInputObj then
                dragging       = false
                activeInputObj = nil
                tw(dot, 0.1, {Size = UDim2.new(0, DOT_S, 0, DOT_S)})
            end
        end)

        -- Tap-without-drag still moves the slider to the tap position
        hb.MouseButton1Click:Connect(function()
            local touches = UIS:GetTouchState()
            -- On a tap-release there may be no active touches; fall back
            -- to the last known AbsolutePosition from the track center
            if touches and #touches > 0 then
                upd(touches[1].Position.X)
            end
        end)
    else
        -- Desktop path: unchanged from original
        hb.MouseButton1Down:Connect(function()
            dragging = true
            tw(dot, 0.1, {Size = UDim2.new(0, DOT_S+4, 0, DOT_S+4)})
        end)

        UIS.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
                tw(dot, 0.1, {Size = UDim2.new(0, DOT_S, 0, DOT_S)})
            end
        end)

        RS.Heartbeat:Connect(function()
            if dragging then
                upd(UIS:GetMouseLocation().X)
            end
        end)

        hb.MouseButton1Click:Connect(function()
            upd(UIS:GetMouseLocation().X)
        end)
    end
end

