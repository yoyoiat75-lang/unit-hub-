local notifQ={}; local notifBusy=false
local function notify(msg, color)
    table.insert(notifQ,{msg=msg, col=color or Color3.fromRGB(196,224,255)})
    if notifBusy then return end
    notifBusy=true
    task.spawn(function()
        while #notifQ>0 do
            local n=table.remove(notifQ,1)
            NotifTxt.Text="  "..n.msg; NotifTxt.TextColor3=n.col
            local bgCol =
                n.col==W.danger  and Color3.fromRGB(64,8,8)   or
                n.col==W.success and Color3.fromRGB(6,32,6)   or
                n.col==W.teal    and Color3.fromRGB(0,32,36)  or
                Color3.fromRGB(0,46,96)
            NotifStrip.BackgroundColor3=bgCol
            -- v5.6: flash the accent bar to match notif color
            tw(NotifAccentBar,0.08,{BackgroundColor3=n.col})
            tw(NotifStrip,0.13,{Size=UDim2.new(1,0,0,20)})
            task.wait(2.6)
            tw(NotifStrip,0.13,{Size=UDim2.new(1,0,0,0)})
            tw(NotifAccentBar,0.13,{BackgroundColor3=W.accent})
            task.wait(0.16)
        end
